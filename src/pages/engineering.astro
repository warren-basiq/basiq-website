---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Basiq Engineering — Go from AI-curious to AI-native. Build an engineering org that runs AI end-to-end."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>Engineering | Basiq</title>
  </head>
  <body
    class="min-h-screen bg-[#0a0a0a] text-[#e8e5e0] antialiased selection:bg-amber-400/20 selection:text-amber-200"
  >
    <!-- Grain overlay -->
    <div
      class="pointer-events-none fixed inset-0 z-50 opacity-[0.03]"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 256px 256px;"
    >
    </div>

    <!-- Nav -->
    <nav
      class="fixed top-0 z-40 w-full border-b border-white/[0.06] bg-[#0a0a0a]/80 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-12"
      >
        <a href="/" aria-label="Basiq home" class="inline-flex items-start">
          <span class="text-2xl font-bold tracking-tight text-white" style="font-family: 'Plus Jakarta Sans', sans-serif;">basiq</span>
          <svg class="ml-[2px] mt-[-3px] h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 6L14 12L8 18" stroke="#4ADE80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M14 6L20 12L14 18" stroke="#4ADE80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <div class="hidden items-center gap-8 md:flex">
          <a
            href="/#services"
            class="text-sm tracking-wide text-[#a09d97] transition-colors hover:text-white"
            >Services</a
          >
          <a
            href="/#work"
            class="text-sm tracking-wide text-[#a09d97] transition-colors hover:text-white"
            >Work</a
          >
          <a
            href="/#about"
            class="text-sm tracking-wide text-[#a09d97] transition-colors hover:text-white"
            >About</a
          >
        </div>
        <div class="flex items-center gap-4">
          <a
            href="/#book-call"
            class="rounded-lg bg-amber-400 px-5 py-2.5 text-sm font-semibold text-[#0a0a0a] transition-all hover:bg-amber-300"
          >
            Book a Call
          </a>
          <button
            id="mobile-menu-btn"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/[0.08] md:hidden"
            aria-label="Toggle menu"
          >
            <svg id="menu-icon-open" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="hidden h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-white/[0.06] bg-[#0a0a0a]/95 backdrop-blur-xl md:hidden">
        <div class="flex flex-col gap-1 px-6 py-4">
          <a href="/#services" class="rounded-lg px-4 py-3 text-sm tracking-wide text-[#a09d97] transition-colors hover:bg-white/[0.04] hover:text-white">Services</a>
          <a href="/#work" class="rounded-lg px-4 py-3 text-sm tracking-wide text-[#a09d97] transition-colors hover:bg-white/[0.04] hover:text-white">Work</a>
          <a href="/#about" class="rounded-lg px-4 py-3 text-sm tracking-wide text-[#a09d97] transition-colors hover:bg-white/[0.04] hover:text-white">About</a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <header class="relative pt-32 pb-20">
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 80px 80px;"
      >
      </div>

      <!-- Ambient glow -->
      <div
        class="absolute left-1/2 top-0 -translate-x-1/2 h-[500px] w-[800px] rounded-full opacity-[0.07]"
        style="background: radial-gradient(ellipse, #F59E0B 0%, transparent 70%);"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-6 lg:px-12">
        <a
          href="/#services"
          class="mb-8 inline-flex items-center gap-2 text-sm text-[#a09d97] transition-colors hover:text-white"
        >
          <span>&larr;</span> All Services
        </a>
        <p
          class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-amber-400/80"
        >
          Engineering
        </p>
        <h1
          class="max-w-4xl text-3xl font-bold leading-[1.1] tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl"
        >
          Going from AI-curious
          <br />
          <span class="text-amber-400">to AI-native.</span>
        </h1>
        <p
          class="mt-8 max-w-2xl font-body text-lg leading-relaxed text-[#a09d97] md:text-xl"
        >
          Most engineering teams are dabbling with AI using Co-Pilot. That's
          fine, but it's not a competitive advantage &mdash; it's table stakes.
          We build engineering organizations that run AI natively end-to-end.
        </p>
        <div class="mt-10">
          <a
            href="/#book-call"
            class="rounded-lg bg-amber-400 px-7 py-3.5 text-sm font-semibold text-[#0a0a0a] transition-all hover:bg-amber-300 hover:shadow-lg hover:shadow-amber-400/20"
          >
            Book a Free Assessment
          </a>
        </div>
      </div>
    </header>

    <!-- What We Build — 3 Pillars -->
    <section class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-6 py-24 lg:px-12 lg:py-32">
        <p
          class="text-sm font-medium uppercase tracking-[0.2em] text-amber-400/80"
        >
          What we build
        </p>
        <h2 class="mt-4 max-w-2xl text-3xl font-bold text-white md:text-4xl">
          Three foundations of an AI-native engineering team
        </h2>

        <div class="mt-16 grid gap-6 md:grid-cols-3">
          <!-- Pillar 1 -->
          <div
            class="group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] transition-all duration-300 hover:border-amber-400/20 hover:bg-white/[0.04]"
          >
            <div class="relative h-48 overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80"
                alt="Code on screen"
                class="h-full w-full object-cover opacity-60 transition-all duration-500 group-hover:scale-105 group-hover:opacity-80"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/40 to-transparent"></div>
              <span class="absolute bottom-4 left-6 font-mono text-sm font-bold text-amber-400/70">01</span>
            </div>
            <div class="p-4 pt-3 sm:p-6 sm:pt-4">
              <h3 class="text-xl font-semibold text-white">
                Claude Code Integration
              </h3>
              <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
                We get your team set up and actually using AI coding tools &mdash;
                not just installed, but integrated into daily workflows. From first
                commit to team-wide adoption.
              </p>
              <p class="mt-5 font-mono text-xs uppercase tracking-wider text-amber-400/50">
                Workflow &middot; Adoption &middot; Training
              </p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div
            class="group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] transition-all duration-300 hover:border-amber-400/20 hover:bg-white/[0.04]"
          >
            <div class="relative h-48 overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=800&q=80"
                alt="AI neural network visualization"
                class="h-full w-full object-cover opacity-60 transition-all duration-500 group-hover:scale-105 group-hover:opacity-80"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/40 to-transparent"></div>
              <span class="absolute bottom-4 left-6 font-mono text-sm font-bold text-amber-400/70">02</span>
            </div>
            <div class="p-4 pt-3 sm:p-6 sm:pt-4">
              <h3 class="text-xl font-semibold text-white">Custom Agents</h3>
              <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
                We help you design and ship your first agents: tools that do real
                work autonomously so your engineers spend time on the hard stuff,
                not the repetitive stuff.
              </p>
              <p class="mt-5 font-mono text-xs uppercase tracking-wider text-amber-400/50">
                Autonomous &middot; Production &middot; Scalable
              </p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div
            class="group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] transition-all duration-300 hover:border-amber-400/20 hover:bg-white/[0.04]"
          >
            <div class="relative h-48 overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=800&q=80"
                alt="Server infrastructure"
                class="h-full w-full object-cover opacity-60 transition-all duration-500 group-hover:scale-105 group-hover:opacity-80"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/40 to-transparent"></div>
              <span class="absolute bottom-4 left-6 font-mono text-sm font-bold text-amber-400/70">03</span>
            </div>
            <div class="p-4 pt-3 sm:p-6 sm:pt-4">
              <h3 class="text-xl font-semibold text-white">AI Infrastructure</h3>
              <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
                Getting the right architecture in place so your AI usage is secure,
                auditable, and scalable &mdash; not a patchwork of personal API
                keys.
              </p>
              <p class="mt-5 font-mono text-xs uppercase tracking-wider text-amber-400/50">
                Secure &middot; Auditable &middot; Enterprise
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Full-width photo break -->
    <section class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-12">
        <div class="relative overflow-hidden rounded-2xl">
          <img
            src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1600&q=80"
            alt="Team collaborating in modern workspace"
            class="h-[280px] w-full object-cover opacity-50 md:h-[360px]"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a]/80 via-transparent to-[#0a0a0a]/80"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a]/60 to-transparent"></div>
          <div class="absolute bottom-8 left-8 md:bottom-12 md:left-12">
            <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-400/60">
              The result
            </p>
            <p class="mt-2 max-w-[calc(100%-2rem)] text-base font-medium text-white/80 sm:max-w-md sm:text-lg md:text-xl">
              An engineering team that ships faster, reviews smarter, and doesn't spend all of its time fixing bugs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- What Changes — 3 Outcomes -->
    <section class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-6 py-24 lg:px-12 lg:py-32">
        <p
          class="text-sm font-medium uppercase tracking-[0.2em] text-amber-400/80"
        >
          The output
        </p>
        <h2 class="mt-4 max-w-2xl text-3xl font-bold text-white md:text-4xl">
          What your engineering team looks like after
        </h2>

        <div class="mt-16 grid gap-0 md:grid-cols-3">
          <!-- Outcome 1 -->
          <div
            class="relative border-l border-white/[0.06] p-5 pl-6 sm:p-8 sm:pl-10 first:border-l-0 md:first:border-l"
          >
            <div
              class="absolute left-0 top-8 h-16 w-px bg-gradient-to-b from-amber-400 to-amber-400/0 md:block hidden"
            >
            </div>
            <div class="mb-3 inline-block rounded-full bg-amber-400/10 px-3 py-1">
              <span class="font-mono text-xs font-medium text-amber-400">
                Ship faster
              </span>
            </div>
            <h3 class="mt-2 text-lg font-semibold text-white">
              Faster PRs, better code
            </h3>
            <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
              Code review, QA, and documentation get handed off to agents.
              Engineers focus on architecture and the problems that actually
              require human judgment.
            </p>
          </div>

          <!-- Outcome 2 -->
          <div
            class="relative border-l border-white/[0.06] p-5 pl-6 sm:p-8 sm:pl-10"
          >
            <div
              class="absolute left-0 top-8 h-16 w-px bg-gradient-to-b from-amber-400 to-amber-400/0 md:block hidden"
            >
            </div>
            <div class="mb-3 inline-block rounded-full bg-amber-400/10 px-3 py-1">
              <span class="font-mono text-xs font-medium text-amber-400">
                Review smarter
              </span>
            </div>
            <h3 class="mt-2 text-lg font-semibold text-white">
              AI-powered PR and audit
            </h3>
            <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
              Every pull request gets an AI-first pass. Security review,
              style enforcement, and documentation happen automatically
              before a human ever looks at the code.
            </p>
          </div>

          <!-- Outcome 3 -->
          <div
            class="relative border-l border-white/[0.06] p-5 pl-6 sm:p-8 sm:pl-10"
          >
            <div
              class="absolute left-0 top-8 h-16 w-px bg-gradient-to-b from-amber-400 to-amber-400/0 md:block hidden"
            >
            </div>
            <div class="mb-3 inline-block rounded-full bg-amber-400/10 px-3 py-1">
              <span class="font-mono text-xs font-medium text-amber-400">
                Scale without hiring
              </span>
            </div>
            <h3 class="mt-2 text-lg font-semibold text-white">
              Don't hire for tasks AI handles
            </h3>
            <p class="mt-3 font-body text-sm leading-relaxed text-[#a09d97]">
              The repetitive work that used to require headcount &mdash;
              boilerplate, migrations, test generation, docs &mdash; gets
              absorbed by agents. Your team grows in capability, not cost.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-6 py-24 lg:px-12 lg:py-32">
        <div class="mx-auto max-w-3xl text-center">
          <h2
            class="text-3xl font-bold text-white md:text-4xl lg:text-5xl"
          >
            Ready to go AI-native?
          </h2>
          <p
            class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-[#a09d97]"
          >
            Every engagement starts with a diagnostic: where are you today,
            where's the highest-value entry point, and what does "fully
            AI-enabled" look like for your team? It's free. It takes a few hours.
          </p>
          <a
            href="/#book-call"
            class="mt-10 inline-block rounded-lg bg-amber-400 px-8 py-4 text-sm font-semibold text-[#0a0a0a] transition-all hover:bg-amber-300 hover:shadow-lg hover:shadow-amber-400/20"
          >
            Book Your Free Assessment
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-12">
        <div
          class="flex flex-col items-center justify-between gap-4 text-xs text-[#706d67] md:flex-row"
        >
          <p>&copy; 2025 Basiq. All rights reserved.</p>
          <div class="flex gap-6">
            <a href="#" class="transition-colors hover:text-white">Privacy</a>
            <a href="#" class="transition-colors hover:text-white">Terms</a>
          </div>
        </div>
      </div>
    </footer>
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        iconOpen?.classList.toggle('hidden');
        iconClose?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
