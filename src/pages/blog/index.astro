---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "../../lib/sanity";

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt: string;
  excerpt: string;
}

let posts: Post[] = [];

if (sanityClient) {
  try {
    posts = await sanityClient.fetch<Post[]>(
      `*[_type == "post"] | order(publishedAt desc) {
        _id,
        title,
        slug,
        publishedAt,
        excerpt
      }`
    );
  } catch {
    // Sanity fetch failed — show empty state
  }
}
---

<Layout title="Blog" description="Insights and updates from the Basiq team">
  <section class="mx-auto max-w-4xl px-6 py-24">
    <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
    <p class="mt-4 text-lg text-gray-600">Insights and updates from the Basiq team.</p>

    {posts.length > 0 ? (
      <div class="mt-12 space-y-10">
        {posts.map((post) => (
          <article class="border-b border-gray-100 pb-10">
            <a href={`/blog/${post.slug.current}`} class="group">
              <h2 class="text-2xl font-semibold group-hover:text-blue-600">{post.title}</h2>
              {post.publishedAt && (
                <time class="mt-2 block text-sm text-gray-400">
                  {new Date(post.publishedAt).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              )}
              {post.excerpt && <p class="mt-3 text-gray-600">{post.excerpt}</p>}
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="mt-12 rounded-lg border border-dashed border-gray-300 p-12 text-center">
        <p class="text-gray-500">No posts yet. Add content in Sanity Studio to get started.</p>
      </div>
    )}
  </section>
</Layout>
