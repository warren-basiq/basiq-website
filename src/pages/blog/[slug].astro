---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "../../lib/sanity";

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt: string;
  excerpt: string;
  body: Array<{
    _type: string;
    children?: Array<{ text: string }>;
    style?: string;
  }>;
}

export async function getStaticPaths() {
  if (!sanityClient) return [];

  let posts: Post[] = [];
  try {
    posts = await sanityClient.fetch<Post[]>(
      `*[_type == "post"] { slug }`
    );
  } catch {
    return [];
  }

  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;

if (!sanityClient) {
  return Astro.redirect("/blog");
}

const post = await sanityClient.fetch<Post>(
  `*[_type == "post" && slug.current == $slug][0] {
    _id,
    title,
    slug,
    publishedAt,
    excerpt,
    body
  }`,
  { slug }
);

if (!post) {
  return Astro.redirect("/blog");
}

function renderBody(body: Post["body"]): string {
  if (!body) return "";
  return body
    .map((block) => {
      if (block._type !== "block" || !block.children) return "";
      const text = block.children.map((c) => c.text).join("");
      switch (block.style) {
        case "h2":
          return `<h2 class="mt-8 text-2xl font-bold">${text}</h2>`;
        case "h3":
          return `<h3 class="mt-6 text-xl font-semibold">${text}</h3>`;
        case "blockquote":
          return `<blockquote class="mt-4 border-l-4 border-gray-300 pl-4 italic text-gray-600">${text}</blockquote>`;
        default:
          return `<p class="mt-4 leading-relaxed">${text}</p>`;
      }
    })
    .join("\n");
}
---

<Layout title={post.title} description={post.excerpt}>
  <article class="mx-auto max-w-3xl px-6 py-24">
    <a href="/blog" class="text-sm text-blue-600 hover:underline">&larr; Back to Blog</a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight">{post.title}</h1>

    {post.publishedAt && (
      <time class="mt-4 block text-sm text-gray-400">
        {new Date(post.publishedAt).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
    )}

    <div class="prose mt-10 max-w-none text-gray-700" set:html={renderBody(post.body)} />
  </article>
</Layout>
