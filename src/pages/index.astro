---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home" description="Basiq — The modern platform for scaling your business">
  <section class="mx-auto max-w-6xl px-6 py-24 text-center">
    <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
      The modern platform for<br />
      <span class="text-blue-600">scaling your business</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
      Basiq gives your team the tools to move faster, close more deals, and deliver
      exceptional experiences — all from one unified platform.
    </p>
    <div class="mt-10 flex items-center justify-center gap-4">
      <a
        href="#"
        class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-medium text-white hover:bg-blue-700"
      >
        Start Free Trial
      </a>
      <a
        href="/pricing"
        class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50"
      >
        View Pricing
      </a>
    </div>
  </section>

  <section class="border-t border-gray-100 bg-gray-50">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-24 sm:grid-cols-3">
      <div>
        <h3 class="text-lg font-semibold">Lightning Fast</h3>
        <p class="mt-2 text-gray-600">Built for speed from the ground up. Every interaction feels instant.</p>
      </div>
      <div>
        <h3 class="text-lg font-semibold">Enterprise Ready</h3>
        <p class="mt-2 text-gray-600">SOC 2 compliant, SSO, and advanced permissions out of the box.</p>
      </div>
      <div>
        <h3 class="text-lg font-semibold">Developer First</h3>
        <p class="mt-2 text-gray-600">APIs, webhooks, and integrations that developers actually enjoy using.</p>
      </div>
    </div>
  </section>
</Layout>
